# terraform_example/.gitignore 파일 

# .gitignore
# Local .terraform directories
**/.terraform/*

# .tfstate files 
*.tfstate
*.tfstate.*
**/.terraform.lock.hcl
**/tfplan

# Crash log files
crash.log

terraform.tfvars

tfplan
*.tfplan

# Lambda 빌드 산출물 (archive_file이 생성하는 zip)
terraform/aws/envs/personal-test/lambda_notify/build/terraform/aws/envs/personal-test/lambda_notify/src/__pycache__/
